# ============================================
# VideoContextBot - Environment Variables
# ============================================
# Copia este archivo a .env y configura tus valores
# cp .env.example .env

# ============================================
# OPENAI-COMPATIBLE API (Requerido)
# ============================================
# Funciona con OpenAI, Groq, DeepSeek, Ollama, etc.

# API Key (obligatoria)
OPENAI_API_KEY=sk-tu-api-key-aqui

# Base URL (opcional, dejar None para OpenAI oficial)
# Groq: https://api.groq.com/openai/v1
# DeepSeek: https://api.deepseek.com/v1
# Ollama local: http://host.docker.internal:11434/v1
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Modelo Whisper (depende del proveedor)
# OpenAI: whisper-1
# Groq: whisper-large-v3, whisper-large-v3-turbo
# WHISPER_MODEL=whisper-large-v3

# ============================================
# API SECURITY (Opcional)
# ============================================
# Si se configura, protege los endpoints de la API
# API_KEY=mi-api-key-secreta

# ============================================
# TELEGRAM BOT (Requerido para el bot)
# ============================================
# Token obtenido de @BotFather
TELEGRAM_BOT_TOKEN=8538919406:AAGROZELCgHKOhi-nPPt9phpfsht_QkwRro

# IDs de usuarios autorizados para usar el bot (separados por comas)
# OBTÉN TU USER ID CON: @userinfobot en Telegram
ALLOWED_USER_IDS=

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# DATABASE (SQLite)
# ============================================
DATABASE_URL=sqlite:///./db/videocontextbot.db

# ============================================
# SERVER PORTS
# ============================================
API_PORT=8000
GRADIO_PORT=7860

# ============================================
# VIDEO PROCESSING
# ============================================
# Tamaño máximo en MB (default: 2048 = 2GB)
MAX_VIDEO_SIZE_MB=2048

# Threshold para detección de escenas (28-35 recomendado para pantallas)
SCENE_DETECT_THRESHOLD=30

# Número de workers Celery concurrentes
CELERY_CONCURRENCY=2

# ============================================
# DIRECTORIOS
# ============================================
OUTPUT_DIR=/app/output
TEMP_DIR=/app/temp
LOGS_DIR=/app/logs

# ============================================
# CLEANUP (en horas)
# ============================================
# Archivos temp se eliminan después de X horas
TEMP_CLEANUP_HOURS=24

# Archivos output se eliminan después de X horas
OUTPUT_CLEANUP_HOURS=48

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
